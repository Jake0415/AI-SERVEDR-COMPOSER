{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash(*)",
      "mcp__playwright__*",
      "mcp__context7__*",
      "mcp__sequential-thinking__*",
      "mcp__shadcn__*",
      "mcp__shrimp-task-manager__*",
      "mcp__slack__*",
      "mcp__claude_ai_Gmail__*",
      "Bash(wait bsx801cw4:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)"
    ],
    "additionalDirectories": [
      "c:\\claude-code\\AI-SERVEDR-COMPOSER\\app\\api\\users"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "postToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "npx tsc --noEmit --pretty 2>&1 | head -20"
      }
    ],
    "stop": [
      {
        "command": "echo '--- 품질 확인 ---' && npx tsc --noEmit 2>&1 | tail -5 && echo '---' && grep -rn 'console\\.log' --include='*.ts' --include='*.tsx' app/ components/ lib/ 2>/dev/null | head -5 && echo '확인 완료'"
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/notification-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  }
}
