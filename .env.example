# ============================================================
# AI-SERVER-COMPOSER 환경변수
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요
# ============================================================

# --- 애플리케이션 설정 ---
NEXT_PUBLIC_APP_NAME="AI-SERVER-COMPOSER"
NEXT_PUBLIC_APP_DESCRIPTION="RFP 기반 인프라 견적서 산출 솔루션"

# --- PostgreSQL 데이터베이스 ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/aisc

# --- JWT 인증 시크릿 ---
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-key

# --- OpenAI (RFP AI 파싱용) ---
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="GPT-5.4 mini"

# --- AES-256 암호화 키 (원가 데이터 보호) ---
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key

# --- Vercel Cron (자동 스냅샷용) ---
CRON_SECRET=your-cron-secret-key

# --- Admin 계정 ---
SUPER_ADMIN_ID=admin@example.com
SUPER_ADMIN_PASSWORD=your-admin-password

# --- 파일 업로드 경로 ---
UPLOAD_DIR=./uploads

# --- Slack API (선택) ---
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_TEAM_ID=your-team-id
# SLACK_CHANNEL=your-channel-id
