# 스킬 참조 정보
# CLAUDE_SKILL_REFERENCE="https://github.com/affaan-m/everything-claude-code/tree/main/rules"
# AWESOME_SKILL_REFERENCE="https://github.com/ComposioHQ/awesome-claude-skills"

# --- 애플리케이션 설정 ---
NEXT_PUBLIC_APP_NAME="AI-SERVER-COMPOSER"
NEXT_PUBLIC_APP_DESCRIPTION="RFP 기반 인프라 견적서 산출 솔루션"

# --- Supabase (필수) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (RFP AI 파싱용) ---
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="GPT-5.4 mini"

# --- Vercel Cron (자동 스냅샷용) ---
CRON_SECRET=your-cron-secret-key


# --- admin test 계{정} ---
SUPER_ADMIN_ID = "yhk71261@gmail.com"
