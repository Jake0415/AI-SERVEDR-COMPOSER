# Next.js 환경변수 예제 파일
# 이 파일을 .env.local로 복사한 후 실제 값을 입력하세요

# 스킬 참조  정보 : claude에서 경로 넣고 주기적으로 필요 사항 적용
# CLAUDE_SKILL_REFERENCE="https://github.com/affaan-m/everything-claude-code/tree/main/rules"
# AWESOME_SKILL_REFERENCE="https://github.com/ComposioHQ/awesome-claude-skills"


# 애플리케이션 설정
NEXT_PUBLIC_APP_NAME="Next.js Starter Kit"
NEXT_PUBLIC_APP_DESCRIPTION="Next.js v15, TypeScript, TailwindCSS v4, shadcn/ui로 구성된 스타터 킷"

# 데이터베이스 (예제)
# DATABASE_URL="postgresql://username:password@localhost:5432/mydb"

# 인증 (예제)
# NEXTAUTH_SECRET="your-secret-key"
# NEXTAUTH_URL="http://localhost:3000"

# API 키 (예제)
# OPENAI_API_KEY="your-openai-api-key"
# STRIPE_SECRET_KEY="your-stripe-secret-key"
# STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

## Slack API 설정
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_TEAM_ID=your-team-id
# SLACK_CHANNEL=your-channel-id
# SLACK_BOT_USER_ID=your-bot-user-id
# SLACK_TARGET_USER_ID=your-target-user-id

## Vercel 배포 설정
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# NEXTAUTH_URL=https://your-app.vercel.app